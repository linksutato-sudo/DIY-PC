import streamlit as st
import json

st.set_page_config(page_title="DIY-PC 智能导购", page_icon="🖥️")
st.title("🖥️ DIY-PC 硬件导购系统")

# --- 1. 安全读取数据 ---
try:
    with open('data/cpus.json', 'r', encoding='utf-8') as f:
        cpu_data = json.load(f)
    with open('data/motherboards.json', 'r', encoding='utf-8') as f:
        mb_data = json.load(f)
except FileNotFoundError:
    st.error("❌ 找不到数据文件！请确保 data 文件夹下有 cpus.json 和 motherboards.json")
    st.stop()

# --- 2. 选择平台与型号 ---
brand = st.radio("选择平台", ["Intel", "AMD"], horizontal=True)
cpus = cpu_data["Intel_Processors"] if brand == "Intel" else cpu_data["AMD_Processors"]

# 获取所有型号名称
model_list = [c["model"] for c in cpus]
selected_model = st.selectbox("选择处理器型号", model_list)

# --- 3. 获取选中 CPU 的详细数据 ---
selected_cpu = next((item for item in cpus if item["model"] == selected_model), None)

if selected_cpu:
    st.divider()
    col1, col2 = st.columns(2)

    with col1:
        st.subheader("📋 处理器详情")
        st.write(f"**型号:** {selected_cpu['model']}")
        st.write(f"**规格:** {selected_cpu.get('specs', '暂无')}")
        
        # 价格逻辑：优先显示散片，没有则显示盒装
        t_price = selected_cpu.get("tray_price")
        b_price = selected_cpu.get("boxed_price")
        
        if t_price and t_price != "缺货":
            st.metric("散片行情价", f"￥{t_price}")
        if b_price:
            st.metric("盒装参考价", f"￥{b_price}")

    with col2:
        st.subheader("🔌 推荐主板")
        # 从 CPU 数据中获取推荐的主板关键字
        mb_hint = selected_cpu.get("supported_motherboards", "")
        
        # 在主板库中搜索匹配的价格
        # 匹配逻辑：如果 CPU 里的推荐字段包含在主板系列名称中
        match = None
        if mb_hint:
            match = next((m for m in mb_data["Motherboard_Series"] if mb_hint.split('/')[0] in m["series"]), None)

        if match:
            st.success(f"**建议搭配:** {match['series']}")
            st.metric("主板参考价", f"￥{match['reference_price']}")
            st.caption(f"包含芯片组: {', '.join(match['chipsets'])}")
        else:
            st.info(f"**建议搭配:** {mb_hint if mb_hint else '请咨询客服'}")
